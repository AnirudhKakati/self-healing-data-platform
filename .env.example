DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/<dbname>
DATABASE_URL_SYNC=postgresql://<user>:<password>@localhost:5432/<dbname>
REDIS_URL=redis://localhost:6379/0
ENV=dev
DATA_WAREHOUSE_URL=postgresql://<user>:<password>@localhost:5432/data_warehouse #For local dev, we create a separate DB on postgres to act as the data warehouse
API_KEY_SECRET=<some_secret_value>
ADMIN_SECRET_KEY=<some_secret_value>